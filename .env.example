# Environment variables for PHP Cognitive Complexity Dev Container
#
# This file serves as a template showing the expected environment variables.
# The actual .env file should be generated using: .docker/generate-env.sh
#
# DO NOT EDIT THIS FILE - it's just for documentation
# Run .docker/generate-env.sh to generate the actual .env file

# Application configuration
APP_NAME=ncac-php-cognitive-complexity
PHP_VERSION=8.2.30
APP_ROOT=/workspace

# WSL2 and XDebug configuration
# These values will be automatically detected when running .docker/generate-env.sh
WSL_IP=192.168.x.x
XDEBUG_PORT=9048

# Generation timestamp (added automatically)
GENERATED_AT=2025-01-01 00:00:00 UTC
